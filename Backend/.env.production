# Loaded when NODE_ENV=production (Render sets that by default).
# Vars already set in the Render dashboard take precedence over this file.
# DATABASE_URL stays in the Render dashboard — never commit secrets here.
ALLOWED_ORIGINS=https://uni-bridge-mu.vercel.app,http://localhost:5173,http://localhost:5174
# Replace with the provisioned public bucket/CDN URL before deploying uploads.
STORAGE_BUCKET_URL=https://your-bucket.s3.your-region.amazonaws.com
