# Copy to observability/.env for local use. Do not commit the copied file.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Start exporters with --profile exporters after setting the real local database credentials.
POSTGRES_EXPORTER_DSN=postgresql://postgres:postgres@host.docker.internal:5432/unibridge?sslmode=disable
REDIS_EXPORTER_ADDRESS=redis://host.docker.internal:6379
