# Django
SECRET_KEY=replace-with-real-django-secret-key
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database
# Local development:
DATABASE_URL=sqlite:///db.sqlite3
# Real UniBridge PostgreSQL example:
# DATABASE_URL=postgresql://username:password@127.0.0.1:5432/unibridge

# FreeLLMAPI
# Change this only if your FreeLLMAPI server is running on another URL.
FREELLMAPI_BASE_URL=http://localhost:3001/v1
# Paste your real FreeLLMAPI unified key here.
FREELLMAPI_API_KEY=freellmapi-your-unified-key
# Keep auto unless you want to force one model.
FREELLMAPI_MODEL=auto

# AI request behavior
AI_TIMEOUT_SECONDS=60
AI_MAX_RETRIES=3
AI_RETRY_BACKOFF_SECONDS=2

# File handling
MEDIA_ROOT=media
MEDIA_URL=/media/
